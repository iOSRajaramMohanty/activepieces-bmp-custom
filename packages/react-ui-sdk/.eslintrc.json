{
  "extends": ["../../.eslintrc.base.json"],
  "ignorePatterns": ["!**/*"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {
        "@nx/enforce-module-boundaries": "off",
        "@typescript-eslint/ban-ts-comment": [
          "error",
          {
            "ts-expect-error": "allow-with-description",
            "ts-ignore": false
          }
        ],
        "@typescript-eslint/no-explicit-any": "warn",
        "@typescript-eslint/no-unused-vars": [
          "warn",
          {
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_"
          }
        ],
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@activepieces/ee-shared",
                "message": "EE packages are not allowed in CE SDK. Use @activepieces/shared instead."
              },
              {
                "name": "ee-embed-sdk",
                "message": "EE embed SDK is not allowed in CE SDK."
              },
              {
                "name": "@activepieces/ee-auth",
                "message": "EE packages are not allowed in CE SDK."
              },
              {
                "name": "@activepieces/ee/billing/ui",
                "message": "EE packages are not allowed in CE SDK."
              }
            ],
            "patterns": [
              {
                "group": ["**/packages/ee/**"],
                "message": "Importing from packages/ee/ is not allowed in CE SDK."
              },
              {
                "group": ["**/packages/server/api/src/app/ee/**"],
                "message": "Importing from server/api/src/app/ee/ is not allowed in CE SDK."
              },
              {
                "group": ["**/ee/**"],
                "message": "Importing from any ee/ directory is not allowed in CE SDK."
              }
            ]
          }
        ]
      }
    }
  ]
}
