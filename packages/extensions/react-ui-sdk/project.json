{
  "name": "react-ui-sdk",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/extensions/react-ui-sdk/src",
  "projectType": "library",
  "tags": [
    "scope:public",
    "type:library",
    "scope:shared",
    "scope:extension"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/packages/extensions/react-ui-sdk",
        "main": "packages/extensions/react-ui-sdk/src/index.ts",
        "tsConfig": "packages/extensions/react-ui-sdk/tsconfig.lib.json",
        "assets": [
          "packages/extensions/react-ui-sdk/LICENSE",
          "packages/extensions/react-ui-sdk/README.md"
        ],
        "generatePackageJson": true,
        "buildableProjectDepsInPackageJsonType": "dependencies"
      },
      "dependsOn": [
        "^build",
        "validate-no-ee-imports"
      ]
    },
    "bundle": {
      "executor": "@nx/webpack:webpack",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "target": "web",
        "compiler": "tsc",
        "outputFileName": "index.js",
        "outputPath": "dist/packages/extensions/react-ui-sdk-bundled",
        "main": "packages/extensions/react-ui-sdk/src/index.browser.entry.ts",
        "tsConfig": "packages/extensions/react-ui-sdk/tsconfig.lib.json",
        "assets": [
          {
            "glob": "LICENSE",
            "input": "packages/extensions/react-ui-sdk",
            "output": "."
          },
          {
            "glob": "README.md",
            "input": "packages/extensions/react-ui-sdk",
            "output": "."
          },
          {
            "glob": "**/*.woff2",
            "input": "packages/web/src/assets/fonts",
            "output": "assets/fonts"
          },
          {
            "glob": "**/*.woff2",
            "input": "packages/web/public/fonts",
            "output": "fonts"
          },
          {
            "glob": "**/*",
            "input": "packages/web/public/locales",
            "output": "locales"
          }
        ],
        "webpackConfig": "packages/extensions/react-ui-sdk/webpack.config.js",
        "generatePackageJson": false,
        "babelUpwardRootMode": true
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false
        }
      },
      "dependsOn": [
        "^build",
        "validate-no-ee-imports",
        "validate-bundle-config"
      ]
    },
    "fix-bundle-package": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/packages/extensions/react-ui-sdk-bundled/package.json"
      ],
      "options": {
        "command": "node packages/extensions/react-ui-sdk/scripts/fix-bundle-package-json.js",
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": [
        "bundle"
      ]
    },
    "build:skip-angular-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/extensions/react-ui-sdk/tsconfig.lib.json --skipLibCheck --noEmit false"
      }
    },
    "validate-no-ee-imports": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node --project tools/tsconfig.tools.json packages/extensions/react-ui-sdk/scripts/validate-ee-exclusion.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "validate-bundle-config": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node packages/extensions/react-ui-sdk/scripts/validate-bundle-config.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "packages/extensions/react-ui-sdk/**/*.ts",
          "packages/extensions/react-ui-sdk/**/*.tsx"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "packages/extensions/react-ui-sdk/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
