{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/packages/extensions/chatbot-sdk",
    "types": ["node"],
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowJs": false,
    "noEmitOnError": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"]
}

