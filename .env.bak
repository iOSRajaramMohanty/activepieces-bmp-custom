# Activepieces Development Environment Configuration
# This file contains environment variables for local development
# DO NOT commit this file to version control (it's in .gitignore)

# ============================================
# CORE CONFIGURATION
# ============================================
AP_EDITION=ce
AP_ENVIRONMENT=dev

# ============================================
# MULTI-TENANCY CONFIGURATION
# ============================================
# Enable multi-tenant mode: Each signup creates an isolated platform
# Set to 'false' to use single-platform mode (team collaboration)
AP_MULTI_TENANT_MODE=true

# Dev mode: Skip invitation checks (legacy, kept for compatibility)
AP_DEV_ALLOW_MULTIPLE_SIGNUPS=true

# ============================================
# PIECES CONFIGURATION
# ============================================
AP_DEV_PIECES=ada-bmp
AP_PIECES_SYNC_MODE=OFFICIAL_AUTO

# ============================================
# DATABASE CONFIGURATION
# ============================================
AP_DB_TYPE=POSTGRES
AP_POSTGRES_DATABASE=activepieces
AP_POSTGRES_HOST=localhost
AP_POSTGRES_PORT=5433
AP_POSTGRES_USERNAME=postgres
AP_POSTGRES_PASSWORD=A79Vm5D4p2VQHOp2gd5
AP_POSTGRES_USE_SSL=false

# ============================================
# REDIS CONFIGURATION
# ============================================
AP_REDIS_HOST=localhost
AP_REDIS_PORT=6379

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Use fixed encryption keys for development (DO NOT use these in production!)
# If you already have connections saved, keep these keys the same
AP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
AP_JWT_SECRET=fedcba9876543210fedcba9876543210

# ============================================
# ADA BMP PIECE CONFIGURATION
# ============================================
ADA_BMP_DEBUG=true
ADA_BMP_TIMEOUT=30000

# ============================================
# FRONTEND & WEBHOOKS CONFIGURATION
# ============================================
# Frontend URL - Used for webhooks and redirects (REQUIRED for webhooks)
AP_FRONTEND_URL=https://overdiversely-preeruptive-margaretta.ngrok-free.dev

# App Webhook Secrets (Optional - Only needed for Slack, Square, etc.)
# Format: JSON object with piece names and their webhook secrets
# See WEBHOOK_SETUP_GUIDE.md for detailed instructions
AP_APP_WEBHOOK_SECRETS='{"@activepieces/piece-slack": {"webhookSecret": "0bf8c65adbf7c9d08575b91e3fb216d5"}}'

# Propagate custom environment variables to sandbox (comma-separated)
AP_SANDBOX_PROPAGATED_ENV_VARS=ADA_BMP_API_URL
# ADA_BMP_API_URL=https://bmpapistgjkt.cl.bmp.ada-asia.my
ADA_BMP_API_URL=https://bmpapidev2.cl.bmp.ada-asia.my
