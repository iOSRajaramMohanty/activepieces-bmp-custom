# ============================================================
# Activepieces — Local Development Environment
# ============================================================
# Used by:
#   - dev-local.sh  (sourced directly into shell)
#   - vite.config.mts  (reads root .env for AP_BMP_ENABLED)
#   - Vite dev server  (auto-loads VITE_* vars for frontend)
#   - Node.js API / worker  (loaded via dotenv)
#
# DO NOT commit this file to version control.
# ============================================================

# ── Core ────────────────────────────────────────────────────
AP_EDITION=ce
AP_ENVIRONMENT=dev

# ── Multi-tenancy ───────────────────────────────────────────
AP_MULTI_TENANT_MODE=true
AP_DEV_ALLOW_MULTIPLE_SIGNUPS=true

# ── BMP Feature Flags ───────────────────────────────────────
# AP_BMP_ENABLED  → read by vite.config.mts to set VITE_BMP_ENABLED at build time
# VITE_BMP_ENABLED → read directly by Vite dev server (exposes to frontend)
AP_BMP_ENABLED=true
VITE_BMP_ENABLED=true
AP_BMP_ORGANIZATIONS=true
AP_BMP_SUPER_ADMIN=true
AP_BMP_ACCOUNT_SWITCHING=true

# ── Pieces ──────────────────────────────────────────────────
AP_DEV_PIECES=ada-bmp,slack,salesforce,hubspot
AP_PIECES_SYNC_MODE=OFFICIAL_AUTO
AP_LOAD_TRANSLATIONS_FOR_DEV_PIECES=false

# ── Database ────────────────────────────────────────────────
AP_DB_TYPE=POSTGRES
AP_POSTGRES_DATABASE=activepieces
AP_POSTGRES_HOST=localhost
AP_POSTGRES_PORT=5433
AP_POSTGRES_USERNAME=postgres
AP_POSTGRES_PASSWORD=A79Vm5D4p2VQHOp2gd5
AP_POSTGRES_USE_SSL=false

# ── Redis / Queue ───────────────────────────────────────────
AP_QUEUE_MODE=REDIS
AP_REDIS_HOST=localhost
AP_REDIS_PORT=6379
AP_QUEUE_UI_ENABLED=true
AP_QUEUE_UI_USERNAME=admin
AP_QUEUE_UI_PASSWORD=admin

# ── Security ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Keep these stable — changing them invalidates existing tokens/connections
AP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
AP_JWT_SECRET=fedcba9876543210fedcba9876543210
AP_API_KEY=api-key

# ── URLs ────────────────────────────────────────────────────
# Vite dev server runs on 4300; API runs on 3000
AP_FRONTEND_URL=http://localhost:4300
AP_WEBHOOK_URL=http://localhost:3000
# AP_INTERNAL_URL is used for OAuth redirect URLs — set to your ngrok/public URL
AP_INTERNAL_URL=https://overdiversely-preeruptive-margaretta.ngrok-free.dev

# ── Logging ─────────────────────────────────────────────────
AP_LOG_LEVEL=debug
AP_LOG_PRETTY=true

# ── Telemetry & Timeouts ────────────────────────────────────
AP_TELEMETRY_ENABLED=false
AP_TRIGGER_DEFAULT_POLL_INTERVAL=1
AP_WEBHOOK_TIMEOUT_SECONDS=30

# ── ADA BMP Piece ───────────────────────────────────────────
ADA_BMP_DEBUG=true
ADA_BMP_TIMEOUT=30000
ADA_BMP_API_URL=https://bmpapi.bmp.ada-asia.my
AP_SANDBOX_PROPAGATED_ENV_VARS=ADA_BMP_API_URL

# ── Webhook Secrets ─────────────────────────────────────────
# Required for Slack/Square/Intercom/Facebook triggers to verify signatures.
# Format: {"@activepieces/piece-name": {"webhookSecret": "SECRET"}}
AP_APP_WEBHOOK_SECRETS='{"@activepieces/piece-slack":{"webhookSecret":"44a41f9cb32e6297acb88817399b3688"}}'

# ── Worker ──────────────────────────────────────────────────
AP_WORKER_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6IjEifQ.eyJpZCI6IjZmYzcyNDNlYjI1ZGVmNGE5OTBiIiwidHlwZSI6IldPUktFUiIsImlhdCI6MTc3NDc5NDQyNywiZXhwIjo0OTI4Mzk0NDI3LCJpc3MiOiJhY3RpdmVwaWVjZXMifQ.YhVg_ZLEEjZIa8qNeMJ-CnLKnC8wB7mDY21SdmOAZWo
