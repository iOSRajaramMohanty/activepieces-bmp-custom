# Copy this file to .env and fill in your values

# ADA BMP Configuration
# Set the API endpoint for ADA BMP service
ADA_BMP_API_URL=https://your-ada-bmp-api-url.com

# Propagate environment variables to sandbox
# CRITICAL: Add any custom env vars your pieces need (comma-separated)
# Without this, custom pieces cannot access environment variables
AP_SANDBOX_PROPAGATED_ENV_VARS=ADA_BMP_API_URL

# Add other environment variables below...
