      ]
    },
    {
      "name": "8. Testing and Runs",
      "item": [
        {
          "name": "ap_test_flow",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 31,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_test_flow\",\n        \"arguments\": { \"flowId\": \"{{flowId}}\" }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Test a flow end-to-end using saved sample data. Polls up to 120 seconds."
          }
        },
        {
          "name": "ap_test_step",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 32,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_test_step\",\n        \"arguments\": { \"flowId\": \"{{flowId}}\", \"stepName\": \"step_1\" }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Test a single step. Runs all steps up to and including the target."
          }
        },
        {
          "name": "ap_retry_run",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 33,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_retry_run\",\n        \"arguments\": {\n            \"flowRunId\": \"{{runId}}\",\n            \"strategy\": \"FROM_FAILED_STEP\"\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
