            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 24,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_manage_notes\",\n        \"arguments\": {\n            \"flowId\": \"{{flowId}}\",\n            \"operation\": \"ADD\",\n            \"content\": \"This flow handles new Salesforce records\",\n            \"color\": \"blue\",\n            \"position\": { \"x\": 300, \"y\": 0 },\n            \"size\": { \"width\": 250, \"height\": 150 }\n        }\n    }\n}"
