{
  "info": {
    "name": "Activepieces MCP Server",
    "description": "Complete Postman collection for validating the Activepieces MCP Server.\n\nSetup:\n1. Set projectId and token in the Variables tab\n2. All requests inherit Bearer auth from the collection\n3. The Accept header (application/json, text/event-stream) is required by Streamable HTTP transport\n\nAll requests use POST to the same endpoint. The MCP method is specified in the JSON-RPC body.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4300/api/v1/projects/{{projectId}}/mcp-server/http",
      "type": "string"
    },
    {
      "key": "projectId",
      "value": "YOUR_PROJECT_ID",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_TOKEN",
      "type": "string"
    },
    {
      "key": "flowId",
      "value": "",
      "type": "string"
    },
    {
      "key": "tableId",
      "value": "",
      "type": "string"
    },
    {
      "key": "runId",
      "value": "",
      "type": "string"
    },
    {
      "key": "recordId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. MCP Protocol",
      "item": [
        {
          "name": "Initialize (Handshake)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 1,\n    \"method\": \"initialize\",\n    \"params\": {\n        \"protocolVersion\": \"2025-03-26\",\n        \"capabilities\": {},\n        \"clientInfo\": { \"name\": \"postman-test\", \"version\": \"1.0.0\" }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "MCP handshake. Confirms the server is alive and returns protocol version and capabilities."
          }
        },
        {
          "name": "List All Tools",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 2,\n    \"method\": \"tools/list\",\n    \"params\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Returns all registered MCP tools with name, description, inputSchema, and annotations."
          }
        }
      ]
    },
    {
      "name": "2. Discovery Tools (always on)",
      "item": [
        {
          "name": "ap_list_flows",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 3,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_list_flows\",\n        \"arguments\": {}\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "List all flows in the current project."
          }
        },
        {
          "name": "ap_flow_structure",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 4,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_flow_structure\",\n        \"arguments\": { \"flowId\": \"{{flowId}}\" }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Get step tree, config status, and valid insert locations for a flow."
          }
        },
        {
          "name": "ap_list_pieces",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 5,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_list_pieces\",\n        \"arguments\": {\n            \"searchQuery\": \"slack\",\n            \"includeActions\": true,\n            \"includeTriggers\": true\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "List available pieces with actions and triggers. Change searchQuery to filter."
          }
        },
        {
          "name": "ap_list_connections",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 6,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_list_connections\",\n        \"arguments\": {}\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "List OAuth/app connections in the project."
          }
        },
        {
          "name": "ap_list_ai_models",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 7,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_list_ai_models\",\n        \"arguments\": {}\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "List configured AI providers and their available models."
          }
        },
        {
          "name": "ap_list_tables",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 8,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_list_tables\",\n        \"arguments\": {}\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "List all tables with fields and row counts."
          }
        },
        {
          "name": "ap_find_records",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 9,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_find_records\",\n        \"arguments\": {\n            \"tableId\": \"{{tableId}}\",\n            \"filters\": [\n                { \"fieldName\": \"status\", \"operator\": \"eq\", \"value\": \"active\" }\n            ],\n            \"limit\": 10\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Query records from a table with optional filtering. Operators: eq, neq, gt, gte, lt, lte, co, exists, not_exists."
          }
        },
        {
          "name": "ap_list_runs",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 10,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_list_runs\",\n        \"arguments\": {\n            \"limit\": 5\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "List recent flow runs. Optional filters: flowId, status, limit."
          }
        },
        {
          "name": "ap_get_run",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 11,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_get_run\",\n        \"arguments\": { \"flowRunId\": \"{{runId}}\" }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Get detailed results of a flow run including step-by-step outputs."
          }
        },
        {
          "name": "ap_setup_guide",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 12,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_setup_guide\",\n        \"arguments\": { \"topic\": \"connection\", \"pieceName\": \"@activepieces/piece-gmail\" }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Get setup instructions for connections or AI providers."
          }
        }
      ]
    },
    {
      "name": "3. Flow Management",
      "item": [
        {
          "name": "ap_create_flow",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 13,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_create_flow\",\n        \"arguments\": { \"flowName\": \"My New Flow\" }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Create a new empty flow. Save the returned flowId."
          }
        },
        {
          "name": "ap_rename_flow",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 14,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_rename_flow\",\n        \"arguments\": { \"flowId\": \"{{flowId}}\", \"displayName\": \"Renamed Flow\" }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Rename an existing flow."
          }
        },
        {
          "name": "ap_lock_and_publish",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 15,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_lock_and_publish\",\n        \"arguments\": { \"flowId\": \"{{flowId}}\" }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Publish and enable the current draft. Returns validation errors if flow is not ready."
          }
        },
        {
          "name": "ap_change_flow_status",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 16,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_change_flow_status\",\n        \"arguments\": { \"flowId\": \"{{flowId}}\", \"status\": \"ENABLED\" }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Enable or disable a flow. Status: ENABLED or DISABLED."
          }
        }
      ]
    },
    {
      "name": "4. Flow Building",
      "item": [
        {
          "name": "ap_update_trigger",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 17,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_update_trigger\",\n        \"arguments\": {\n            \"flowId\": \"{{flowId}}\",\n            \"pieceName\": \"@activepieces/piece-schedule\",\n            \"pieceVersion\": \"~0.2.0\",\n            \"triggerName\": \"every_hour_trigger\"\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Set or update the trigger. Use ap_list_pieces to get valid pieceName, pieceVersion, triggerName."
          }
        },
        {
          "name": "ap_add_step (PIECE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 18,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_add_step\",\n        \"arguments\": {\n            \"flowId\": \"{{flowId}}\",\n            \"parentStepName\": \"trigger\",\n            \"stepLocationRelativeToParent\": \"AFTER\",\n            \"stepType\": \"PIECE\",\n            \"displayName\": \"Send Slack Message\",\n            \"pieceName\": \"@activepieces/piece-slack\",\n            \"pieceVersion\": \"~0.5.0\",\n            \"actionName\": \"send_channel_message\"\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Add a PIECE step skeleton. Configure afterwards with ap_update_step."
          }
        },
        {
          "name": "ap_add_step (CODE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 19,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_add_step\",\n        \"arguments\": {\n            \"flowId\": \"{{flowId}}\",\n            \"parentStepName\": \"trigger\",\n            \"stepLocationRelativeToParent\": \"AFTER\",\n            \"stepType\": \"CODE\",\n            \"displayName\": \"Transform Data\"\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Add a CODE step skeleton. Note: source code must be edited in the Activepieces UI (known limitation)."
          }
        },
        {
          "name": "ap_update_step",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 20,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_update_step\",\n        \"arguments\": {\n            \"flowId\": \"{{flowId}}\",\n            \"stepName\": \"step_1\",\n            \"input\": {\n                \"channel\": \"general\",\n                \"text\": \"Hello from MCP! {{trigger.output.message}}\"\n            }\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Update step settings. Works best for PIECE steps. Use auth field for connection externalId."
          }
        },
        {
          "name": "ap_delete_step",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 21,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_delete_step\",\n        \"arguments\": { \"flowId\": \"{{flowId}}\", \"stepName\": \"step_1\" }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Delete a step from a flow."
          }
        }
      ]
    },
    {
      "name": "5. Router and Branching",
      "item": [
        {
          "name": "ap_add_branch",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 22,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_add_branch\",\n        \"arguments\": {\n            \"flowId\": \"{{flowId}}\",\n            \"routerStepName\": \"step_1\",\n            \"branchName\": \"High Priority\",\n            \"conditions\": [[{\n                \"firstValue\": \"{{trigger.output.priority}}\",\n                \"operator\": \"TEXT_CONTAINS\",\n                \"secondValue\": \"high\"\n            }]]\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Add a conditional branch to a ROUTER step."
          }
        },
        {
          "name": "ap_delete_branch",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 23,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_delete_branch\",\n        \"arguments\": {\n            \"flowId\": \"{{flowId}}\",\n            \"routerStepName\": \"step_1\",\n            \"branchIndex\": 0\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Delete a branch from a ROUTER step. Cannot delete the fallback (last) branch."
          }
        }
      ]
    },
