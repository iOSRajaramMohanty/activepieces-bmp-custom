    {
      "name": "7. Tables",
      "item": [
        {
          "name": "ap_create_table",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 25,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_create_table\",\n        \"arguments\": {\n            \"name\": \"Contacts\",\n            \"fields\": [\n                { \"name\": \"Name\", \"type\": \"TEXT\" },\n                { \"name\": \"Email\", \"type\": \"TEXT\" },\n                { \"name\": \"Age\", \"type\": \"NUMBER\" },\n                { \"name\": \"Status\", \"type\": \"STATIC_DROPDOWN\", \"options\": [\"Active\", \"Inactive\"] }\n            ]\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Create a table. Field types: TEXT, NUMBER, DATE, STATIC_DROPDOWN."
          }
        },
        {
          "name": "ap_manage_fields (ADD)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 26,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_manage_fields\",\n        \"arguments\": {\n            \"tableId\": \"{{tableId}}\",\n            \"operation\": \"ADD\",\n            \"name\": \"Phone\",\n            \"type\": \"TEXT\"\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Add, rename, or delete fields. Operations: ADD, UPDATE, DELETE."
          }
        },
        {
          "name": "ap_insert_records",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 27,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_insert_records\",\n        \"arguments\": {\n            \"tableId\": \"{{tableId}}\",\n            \"records\": [\n                { \"Name\": \"Alice\", \"Email\": \"alice@example.com\", \"Age\": \"30\", \"Status\": \"Active\" },\n                { \"Name\": \"Bob\", \"Email\": \"bob@example.com\", \"Age\": \"25\", \"Status\": \"Inactive\" }\n            ]\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Insert 1-50 records. Use field names (not IDs)."
          }
        },
        {
          "name": "ap_update_record",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 28,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_update_record\",\n        \"arguments\": {\n            \"tableId\": \"{{tableId}}\",\n            \"recordId\": \"{{recordId}}\",\n            \"fields\": { \"Status\": \"Active\" }\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Update specific cells in a record. Only specified fields are changed."
          }
        },
        {
          "name": "ap_delete_records",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 29,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_delete_records\",\n        \"arguments\": { \"recordIds\": [\"{{recordId}}\"] }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Permanently delete one or more records."
          }
        },
        {
          "name": "ap_delete_table",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json, text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 30,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"ap_delete_table\",\n        \"arguments\": { \"tableId\": \"{{tableId}}\" }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
